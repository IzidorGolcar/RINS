# =============================================================================
# GENERAL .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# OS FILES
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# -----------------------------------------------------------------------------
# EDITORS & IDEs
# -----------------------------------------------------------------------------
# VS Code
.vscode/
!.vscode/extensions.json

# JetBrains (PyCharm, IntelliJ, WebStorm, etc.)
.idea/
*.iml
*.iws
*.ipr

# Vim / Neovim
*.swp
*.swo
*~
.netrwhist

# Emacs
*#
.\#*

# Sublime Text
*.sublime-project
*.sublime-workspace

# Eclipse
.classpath
.project
.settings/

# -----------------------------------------------------------------------------
# PYTHON
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python
.venv/
venv/
env/
ENV/
.env
.env.*
!.env.example
pip-log.txt
pip-delete-this-directory.txt
*.egg-info/
*.egg
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.tox/
.nox/
*.ipynb_checkpoints/
.jupyter/
profile_default/
ipython_config.py
*.spec

# -----------------------------------------------------------------------------
# NODE / JAVASCRIPT / TYPESCRIPT
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.npm
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*
dist/
out/
.next/
.nuxt/
.cache/
.parcel-cache/
.turbo/
.svelte-kit/

# -----------------------------------------------------------------------------
# ENVIRONMENT & SECRETS
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.cert
*.crt
secrets.*
config.local.*
*.secret

# -----------------------------------------------------------------------------
# LOGS & TEMP FILES
# -----------------------------------------------------------------------------
*.log
logs/
tmp/
temp/
*.tmp
*.bak
*.orig
*.rej

# -----------------------------------------------------------------------------
# COMPILED & BUILD OUTPUT
# -----------------------------------------------------------------------------
*.o
*.a
*.so
*.dll
*.exe
*.out
*.class
*.jar

# -----------------------------------------------------------------------------
# ARCHIVES
# -----------------------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

# -----------------------------------------------------------------------------
# DATA & LARGE FILES
# -----------------------------------------------------------------------------
*.csv
*.tsv
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.pickle
*.npy
*.npz
*.pt
*.pth
*.ckpt
*.safetensors

# -----------------------------------------------------------------------------
# DATABASES
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db

# -----------------------------------------------------------------------------
# DOCKER
# -----------------------------------------------------------------------------
.docker/
docker-compose.override.yml

# -----------------------------------------------------------------------------
# TERRAFORM
# -----------------------------------------------------------------------------
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example

# -----------------------------------------------------------------------------
# MISC
# -----------------------------------------------------------------------------
.cache/
.sass-cache/
*.pid
*.seed
*.pid.lock
.grunt
.lock-wscript
